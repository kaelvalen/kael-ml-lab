   "source": [
    "try:\n",
    "    number: int = int(input())\n",
    "except:\n",
    "    print(\"Please enter an integer.\")\n",
    "def collatz(number):\n",
    "    if (number % 2) == 0:\n",
    "        print(number // 2)\n",
    "        return number // 2\n",
    "    else:\n",
    "        print(3 * number + 1)\n",
    "        return 3 * number + 1"
   ]
